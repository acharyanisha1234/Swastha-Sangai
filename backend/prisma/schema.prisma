generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DonationApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                Int       @id @default(autoincrement())
  fullName          String
  email             String    @unique
  password          String
  age               String?
  weight            String?
  height            String?
  goal              String?
  profileImage      String?

  sentRequests      FriendRequest[] @relation("SentRequests")
  receivedRequests  FriendRequest[] @relation("ReceivedRequests")

  friends           Friend[]  @relation("UserToFriends")
  friendOf          Friend[]  @relation("FriendToUsers")

  donationPosts     DonationPost[]
  donationApplications DonationApplication[]

  comments          Comment[]

  verifyOtp         String    @default("")
  verifyOtpExpireAt BigInt    @default(0)

  isAccountVerified Boolean   @default(false)

  resetOtp          String    @default("")
  resetOtpExpireAt  BigInt    @default(0)

  workouts          WorkoutLog[]
  
  // Chat relations
  chatSessions      ChatSession[]
  chatMessages      ChatMessage[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model DonationPost {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?

  creatorId   Int
  creator     User     @relation(fields: [creatorId], references: [id])

  applications DonationApplication[]
  comments    Comment[]

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  userId    Int
  postId    Int
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      DonationPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DonationApplication {
  id              Int      @id @default(autoincrement())
  userId          Int
  donationPostId  Int?
  user            User         @relation(fields: [userId], references: [id])
  donationPost    DonationPost? @relation(fields: [donationPostId], references: [id], onDelete: SetNull)
  status          DonationApplicationStatus @default(PENDING)
  message         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, donationPostId])
}

model Friend {
  id        Int  @id @default(autoincrement())
  userId    Int
  friendId  Int
  user      User @relation("UserToFriends", fields: [userId], references: [id])
  friend    User @relation("FriendToUsers", fields: [friendId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, friendId])
}

model FriendRequest {
  id          Int      @id @default(autoincrement())
  senderId    Int
  receiverId  Int
  status      FriendRequestStatus @default(PENDING)
  sender      User @relation("SentRequests", fields: [senderId], references: [id])
  receiver    User @relation("ReceivedRequests", fields: [receiverId], references: [id])
  createdAt   DateTime @default(now())
  respondedAt DateTime?

  @@unique([senderId, receiverId])
}

model WorkoutLog {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  workoutDate      DateTime  @map("workout_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  verified         Boolean   @default(false)
  verificationType String?
  workoutDuration  Int?
  workoutType      String?
  verifiedAt       DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workoutDate])
  @@map("workout_logs")
}

// ============= CHAT SYSTEM MODELS =============

model ChatSession {
  id        String        @id @default(cuid())
  userId    Int?
  title     String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ChatMessage {
  id        String        @id @default(cuid())
  content   String        @db.Text
  role      String        // 'user' or 'assistant'
  imageUrl  String?       // For image messages
  imageName String?       // Original image name
  sessionId String
  userId    Int?
  createdAt DateTime      @default(now())
  
  session   ChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
}